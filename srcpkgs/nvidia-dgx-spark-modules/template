# Template file for 'nvidia-dgx-spark-modules'
# NVIDIA 580.142 open kernel modules for DGX Spark
# Pre-built against linux-dgx-spark (no DKMS)
pkgname=nvidia-dgx-spark-modules
version=580.142
revision=1
_sfx="-0ubuntu0.24.04.1"
_kernver=6.17.9_1
create_wrksrc=yes
short_desc="NVIDIA 580.142 open kernel modules for DGX Spark"
maintainer="Void DGX Spark <void-dgx-spark@example.com>"
license="GPL-2.0-only, custom:NVIDIA"
homepage="https://www.nvidia.com/"

archs="aarch64"
repository=nonfree
nostrip=yes
noverifyrdeps=yes

hostmakedepends="tar zstd"
makedepends="linux-dgx-spark-headers"
depends="linux-dgx-spark>=${_kernver%_*}"

_ppa="https://snapshot.ppa.launchpadcontent.net/canonical-nvidia/nvidia-desktop-edge/ubuntu/pool/main/n/nvidia-graphics-drivers-580"
_deb="nvidia-kernel-source-580-open_${version}${_sfx}_arm64.deb"
_cksum="c61ec87e944645379dba248eaafb933dddbebef6f46e8b0741f33b22c928ccdb"

do_fetch() {
	local _srcdir="${XBPS_SRCDISTDIR}/${pkgname}-${version}"
	mkdir -p "${_srcdir}"
	if [ ! -f "${_srcdir}/${_deb}" ]; then
		xbps-fetch -o "${_srcdir}/${_deb}" "${_ppa}/${_deb}"
	fi
	echo "${_cksum}  ${_srcdir}/${_deb}" | sha256sum -c
}

do_extract() {
	local _srcdir="${XBPS_SRCDISTDIR}/${pkgname}-${version}"
	ar x "${_srcdir}"/*.deb
	tar xf data.tar.*
	rm -f control.tar.* data.tar.* debian-binary
}

do_build() {
	local _cross_args="" _sysroot=""
	if [ "$CROSS_BUILD" ]; then
		_cross_args="CROSS_COMPILE=${XBPS_CROSS_TRIPLET}-"
		_sysroot="${XBPS_CROSS_BASE}"
	fi

	cd usr/src/nvidia-${version}
	make ${makejobs} \
		ARCH=arm64 \
		${_cross_args} \
		KERNEL_UNAME=${_kernver} \
		SYSSRC="${_sysroot}/usr/src/kernel-headers-${_kernver}" \
		NV_EXCLUDE_BUILD_MODULES='' \
		modules
}

do_install() {
	local _moddir="${DESTDIR}/usr/lib/modules/${_kernver}/extra/nvidia"
	vmkdir usr/lib/modules/${_kernver}/extra/nvidia

	cd usr/src/nvidia-${version}
	for mod in nvidia nvidia-modeset nvidia-drm nvidia-uvm nvidia-peermem; do
		if [ -f "${mod}.ko" ]; then
			install -Dm644 "${mod}.ko" "${_moddir}/${mod}.ko"
		elif [ -f "${mod}/${mod}.ko" ]; then
			install -Dm644 "${mod}/${mod}.ko" "${_moddir}/${mod}.ko"
		fi
	done

	# Compress modules
	find "${_moddir}" -name "*.ko" -exec zstd --rm -f -q {} \;
}
