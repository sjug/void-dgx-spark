# Template file for 'nvidia-spark-initcall-bl'
# 1:1 with Ubuntu package of the same name
# Adds initcall_blacklist=tegra234_cbb_init to kernel cmdline
pkgname=nvidia-spark-initcall-bl
version=1.0
revision=1
short_desc="Blacklist tegra234_cbb_init initcall for DGX Spark"
maintainer="Void DGX Spark <void-dgx-spark@example.com>"
license="custom:NVIDIA"
homepage="https://www.nvidia.com/"
create_wrksrc=yes
archs="aarch64"

do_install() {
	vinstall ${FILESDIR}/cmdline-initcall-bl.conf 644 usr/share/dgx-spark/cmdline.d
}
