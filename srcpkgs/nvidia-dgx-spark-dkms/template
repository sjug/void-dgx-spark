# Template file for 'nvidia-dgx-spark-dkms'
# NVIDIA 580.142 open kernel module source for DGX Spark
pkgname=nvidia-dgx-spark-dkms
version=580.142
revision=1
_sfx="-0ubuntu0.24.04.1"
create_wrksrc=yes
short_desc="NVIDIA 580.142 open kernel modules for DGX Spark (DKMS)"
maintainer="Void DGX Spark <void-dgx-spark@example.com>"
license="GPL-2.0-only, custom:NVIDIA"
homepage="https://www.nvidia.com/"

archs="aarch64"
repository=nonfree
nostrip=yes

hostmakedepends="tar zstd"
depends="dkms linux-dgx-spark-headers"
dkms_modules="nvidia ${version}"
triggers="dkms initramfs-regenerate"

_ppa="https://snapshot.ppa.launchpadcontent.net/canonical-nvidia/nvidia-desktop-edge/ubuntu/pool/main/n/nvidia-graphics-drivers-580"
_deb="nvidia-kernel-source-580-open_${version}${_sfx}_arm64.deb"
_cksum="c61ec87e944645379dba248eaafb933dddbebef6f46e8b0741f33b22c928ccdb"

do_fetch() {
	local _srcdir="${XBPS_SRCDISTDIR}/${pkgname}-${version}"
	mkdir -p "${_srcdir}"
	if [ ! -f "${_srcdir}/${_deb}" ]; then
		xbps-fetch -o "${_srcdir}/${_deb}" "${_ppa}/${_deb}"
	fi
	echo "${_cksum}  ${_srcdir}/${_deb}" | sha256sum -c
}

do_extract() {
	local _srcdir="${XBPS_SRCDISTDIR}/${pkgname}-${version}"
	ar x "${_srcdir}"/*.deb
	tar xf data.tar.*
	rm -f control.tar.* data.tar.* debian-binary
}

do_install() {
	if [ -d usr/src/nvidia-${version} ]; then
		vmkdir usr/src
		cp -a usr/src/nvidia-${version} ${DESTDIR}/usr/src/
	fi

	vinstall ${FILESDIR}/dkms.conf 644 usr/src/nvidia-${version}
	sed -e "s/__PKGVER/${version}/g" \
		-e 's/__MAKEJOBS/-j$(nproc)/g' \
		-i ${DESTDIR}/usr/src/nvidia-${version}/dkms.conf
}
