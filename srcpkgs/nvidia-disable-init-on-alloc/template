# Template file for 'nvidia-disable-init-on-alloc'
# 1:1 with Ubuntu package of the same name
# On Ubuntu this is a first-boot systemd service that writes a grub.d config.
# On Void we install the kernel cmdline config directly.
pkgname=nvidia-disable-init-on-alloc
version=24.10
revision=1
short_desc="Disable init_on_alloc kernel parameter for DGX Spark"
maintainer="Void DGX Spark <void-dgx-spark@example.com>"
license="custom:NVIDIA"
homepage="https://www.nvidia.com/"
create_wrksrc=yes
archs="aarch64"

do_install() {
	vmkdir usr/lib/kernel.d
	vinstall ${FILESDIR}/cmdline-init-on-alloc.conf 644 usr/share/dgx-spark/cmdline.d
}
