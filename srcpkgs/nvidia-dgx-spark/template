# Template file for 'nvidia-dgx-spark'
# NVIDIA 580.142 userspace driver for DGX Spark (aarch64)
# URLs and checksums verified from sparky 2026-03-24
pkgname=nvidia-dgx-spark
version=580.142
revision=1
_sfx="-0ubuntu0.24.04.1"
create_wrksrc=yes
short_desc="NVIDIA 580.142 userspace driver for DGX Spark (GB10)"
maintainer="Void DGX Spark <void-dgx-spark@example.com>"
license="custom:NVIDIA"
homepage="https://www.nvidia.com/"

archs="aarch64"
repository=nonfree
nostrip=yes
noverifyrdeps=yes
noshlibprovides=yes

hostmakedepends="tar zstd patchelf"
depends="nvidia-dgx-spark-firmware>=${version}"

_ppa="https://snapshot.ppa.launchpadcontent.net/canonical-nvidia/nvidia-desktop-edge/ubuntu/pool/main/n/nvidia-graphics-drivers-580"

_debs="
nvidia-utils-580_${version}${_sfx}_arm64.deb:ec040f9e6fca6e759f5b9202bf2649a768d4cfaa4fa073780f926f08be6728ab
libnvidia-compute-580_${version}${_sfx}_arm64.deb:c4d57bd41f095d4be16298466776f4ef6f2f13ad1df11ed9b5aacdb1c8ff38cf
libnvidia-gl-580_${version}${_sfx}_arm64.deb:04acb51342fcda0e420923b763696b92789dfd11866bfc326c42f3d56c2e5c21
libnvidia-encode-580_${version}${_sfx}_arm64.deb:8e135a15e5f55b5a3bc6a01bb6652fdc47b525c1451c673d289a32b712fbcc21
libnvidia-decode-580_${version}${_sfx}_arm64.deb:ccf924e3e025726040e31da9d25efca42817a2478a391067090e951b97c586d1
libnvidia-extra-580_${version}${_sfx}_arm64.deb:156d05cce03c7b8a6e41eb737e89db2857789033ac0a87a17aba5d9fe612647d
libnvidia-fbc1-580_${version}${_sfx}_arm64.deb:543e649f3c1abc472303f0807d50a0d2fb36ee17f85a7a4bd4b37d2e8f989363
nvidia-kernel-common-580_${version}${_sfx}_arm64.deb:102752db0c6aa0aa1a669125e972e8e02138b10dd69e5141d4af0ee54f3edb45
"

do_fetch() {
	local _srcdir="${XBPS_SRCDISTDIR}/${pkgname}-${version}"
	mkdir -p "${_srcdir}"
	for entry in ${_debs}; do
		local _file="${entry%%:*}"
		local _sum="${entry##*:}"
		if [ ! -f "${_srcdir}/${_file}" ]; then
			msg_normal "Fetching ${_file}...\n"
			xbps-fetch -o "${_srcdir}/${_file}" "${_ppa}/${_file}"
		fi
		echo "${_sum}  ${_srcdir}/${_file}" | sha256sum -c
	done
}

do_extract() {
	local _srcdir="${XBPS_SRCDISTDIR}/${pkgname}-${version}"
	for f in "${_srcdir}"/*.deb; do
		ar x "$f"
		tar xf data.tar.*
		rm -f control.tar.* data.tar.* debian-binary
	done
}

do_install() {
	# Binaries
	for bin in usr/bin/*; do
		[ -f "$bin" ] && vbin "$bin"
	done

	# Libraries (from aarch64-linux-gnu to usr/lib)
	vmkdir usr/lib
	if [ -d usr/lib/aarch64-linux-gnu ]; then
		cp -a usr/lib/aarch64-linux-gnu/*.so* ${DESTDIR}/usr/lib/ 2>/dev/null || true
		for d in usr/lib/aarch64-linux-gnu/*/; do
			[ -d "$d" ] && cp -a "$d" ${DESTDIR}/usr/lib/ 2>/dev/null || true
		done
	fi

	# Vulkan ICD, EGL vendor, GLVND configs
	for dir in usr/share/vulkan usr/share/egl usr/share/glvnd; do
		if [ -d "$dir" ]; then
			vmkdir ${dir}
			cp -a ${dir}/* ${DESTDIR}/${dir}/
		fi
	done

	# nvidia-persistenced runit service
	vsv nvidia-persistenced

	# Blacklist nouveau
	vmkdir usr/lib/modprobe.d
	echo "blacklist nouveau" > ${DESTDIR}/usr/lib/modprobe.d/nvidia.conf

	# Fix interpreter for Void
	find ${DESTDIR}/usr/bin -type f -executable | while read f; do
		patchelf --set-interpreter /usr/lib/ld-linux-aarch64.so.1 "$f" 2>/dev/null || true
	done

	vlicense usr/share/doc/nvidia-utils-580/copyright
}
