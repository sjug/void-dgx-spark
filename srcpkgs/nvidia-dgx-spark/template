# Template file for 'nvidia-dgx-spark'
# NVIDIA 580.142 userspace driver for DGX Spark (aarch64)
# URLs and checksums verified from sparky 2026-03-26
pkgname=nvidia-dgx-spark
version=580.142
revision=2
_sfx="-0ubuntu0.24.04.1"
create_wrksrc=yes
short_desc="NVIDIA 580.142 userspace driver for DGX Spark (GB10)"
maintainer="Void DGX Spark <void-dgx-spark@example.com>"
license="custom:NVIDIA"
homepage="https://www.nvidia.com/"

archs="aarch64"
repository=nonfree
nostrip=yes
noverifyrdeps=yes
noshlibprovides=yes

hostmakedepends="tar xz zstd patchelf"
depends="nvidia-dgx-spark-firmware>=${version}"

_ppa="https://snapshot.ppa.launchpadcontent.net/canonical-nvidia/nvidia-desktop-edge/ubuntu/pool/main/n/nvidia-graphics-drivers-580"
_cuda_repo="https://developer.download.nvidia.com/compute/cuda/repos/ubuntu2404/sbsa"

_debs="
