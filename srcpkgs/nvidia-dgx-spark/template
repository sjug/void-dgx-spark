# nvidia-modprobe comes from CUDA repo, different version
_modprobe_deb="nvidia-modprobe_595.58.03-1ubuntu1_arm64.deb"
_modprobe_sum="edb69ae6c1abac1432fd4d478262c00b162379779eea41c84d10c70555a154bf4faca2fb3814ea688e3d74fd808a6717e06af72890ebffb329b8242fba7ca986"

do_fetch() {
	local _srcdir="${XBPS_SRCDISTDIR}/${pkgname}-${version}"
	mkdir -p "${_srcdir}"
	for entry in ${_debs}; do
		local _file="${entry%%:*}"
		local _rest="${entry#*:}"
		local _sum="${_rest%%:*}"
		local _url="${_rest#*:}"
		if [ ! -f "${_srcdir}/${_file}" ]; then
			msg_normal "Fetching ${_file}...\n"
			xbps-fetch -o "${_srcdir}/${_file}" "${_url}/${_file}"
		fi
		echo "${_sum}  ${_srcdir}/${_file}" | sha256sum -c
	done
	# nvidia-modprobe from CUDA repo
	if [ ! -f "${_srcdir}/${_modprobe_deb}" ]; then
		msg_normal "Fetching ${_modprobe_deb}...\n"
		xbps-fetch -o "${_srcdir}/${_modprobe_deb}" "${_cuda_repo}/${_modprobe_deb}"
	fi
}

do_extract() {
	local _srcdir="${XBPS_SRCDISTDIR}/${pkgname}-${version}"
	for f in "${_srcdir}"/*.deb; do
		ar x "$f"
		tar xf data.tar.*
		rm -f control.tar.* data.tar.* debian-binary
	done
}

do_install() {
	# Binaries
	for bin in usr/bin/*; do
		[ -f "$bin" ] && vbin "$bin"
	done

	# Libraries (from aarch64-linux-gnu to usr/lib)
	vmkdir usr/lib
	if [ -d usr/lib/aarch64-linux-gnu ]; then
		cp -a usr/lib/aarch64-linux-gnu/*.so* ${DESTDIR}/usr/lib/ 2>/dev/null || true
		for d in usr/lib/aarch64-linux-gnu/*/; do
			[ -d "$d" ] && cp -a "$d" ${DESTDIR}/usr/lib/ 2>/dev/null || true
		done
	fi

	# Vulkan ICD, EGL vendor, GLVND configs, nvidia application profiles
	for dir in usr/share/vulkan usr/share/egl usr/share/glvnd usr/share/nvidia; do
		if [ -d "$dir" ]; then
			vmkdir ${dir}
			cp -a ${dir}/* ${DESTDIR}/${dir}/
		fi
	done

	# ub-device-create from nvidia-kernel-common-580 (creates /dev/nvidia* nodes)
	if [ -f sbin/ub-device-create ]; then
		vbin sbin/ub-device-create
	fi

	# udev rule from nvidia-kernel-common-580, with systemd line removed
	# (nvidia-persistenced is handled by runit service instead)
	if [ -f lib/udev/rules.d/71-nvidia.rules ]; then
		vmkdir usr/lib/udev/rules.d
		sed -e 's|TAG+="systemd", ENV{SYSTEMD_WANTS}="nvidia-persistenced.service"|RUN+="/usr/bin/sv start nvidia-persistenced"|' \
			-e 's|/sbin/ub-device-create|/usr/bin/ub-device-create|g' \
			-e 's|/sbin/modprobe|/usr/bin/modprobe|g' \
			lib/udev/rules.d/71-nvidia.rules \
			> ${DESTDIR}/usr/lib/udev/rules.d/71-nvidia.rules
		chmod 644 ${DESTDIR}/usr/lib/udev/rules.d/71-nvidia.rules
	fi

	# modprobe config from nvidia-kernel-common-580
	vmkdir usr/lib/modprobe.d
	if [ -f lib/modprobe.d/nvidia-graphics-drivers.conf ]; then
		cp lib/modprobe.d/nvidia-graphics-drivers.conf \
			${DESTDIR}/usr/lib/modprobe.d/
	fi

	# OpenCL ICD from libnvidia-compute-580
	if [ -d etc/OpenCL/vendors ]; then
		vmkdir etc/OpenCL/vendors
		cp etc/OpenCL/vendors/*.icd ${DESTDIR}/etc/OpenCL/vendors/
	fi

	# nvidia-persistenced runit service
	vsv nvidia-persistenced

	# Fix interpreter for Void
	find ${DESTDIR}/usr/bin ${DESTDIR}/usr/sbin -type f -executable | while read f; do
		patchelf --set-interpreter /usr/lib/ld-linux-aarch64.so.1 "$f" 2>/dev/null || true
	done

	# Set setuid bit on nvidia-modprobe AFTER patchelf (patchelf rewrites the
	# binary and strips setuid). nvidia-modprobe needs setuid to create
	# /dev/nvidia* device nodes as non-root.
	chmod 6755 ${DESTDIR}/usr/bin/nvidia-modprobe

	vlicense usr/share/doc/nvidia-utils-580/copyright
}
