libnvidia-compute-580_${version}${_sfx}_arm64.deb:c4d57bd41f095d4be16298466776f4ef6f2f13ad1df11ed9b5aacdb1c8ff38cf:${_ppa}
libnvidia-gl-580_${version}${_sfx}_arm64.deb:04acb51342fcda0e420923b763696b92789dfd11866bfc326c42f3d56c2e5c21:${_ppa}
libnvidia-encode-580_${version}${_sfx}_arm64.deb:8e135a15e5f55b5a3bc6a01bb6652fdc47b525c1451c673d289a32b712fbcc21:${_ppa}
libnvidia-decode-580_${version}${_sfx}_arm64.deb:ccf924e3e025726040e31da9d25efca42817a2478a391067090e951b97c586d1:${_ppa}
libnvidia-extra-580_${version}${_sfx}_arm64.deb:156d05cce03c7b8a6e41eb737e89db2857789033ac0a87a17aba5d9fe612647d:${_ppa}
libnvidia-fbc1-580_${version}${_sfx}_arm64.deb:543e649f3c1abc472303f0807d50a0d2fb36ee17f85a7a4bd4b37d2e8f989363:${_ppa}
nvidia-kernel-common-580_${version}${_sfx}_arm64.deb:102752db0c6aa0aa1a669125e972e8e02138b10dd69e5141d4af0ee54f3edb45:${_ppa}
nvidia-compute-utils-580_${version}${_sfx}_arm64.deb:52cd9afd12e25a998866bf2b4a5664677af5e60b14124f427ba5733458ff4d8a:${_ppa}
libnvidia-cfg1-580_${version}${_sfx}_arm64.deb:f6ffa7c52f1f441373790b9d5f218122f38baab4b4cdc93ffbebc6b207420a01:${_ppa}
libnvidia-common-580_${version}${_sfx}_all.deb:ec7095dfafdcaec64efba61b69a0a1c58100a18f8b48b1bb850be286f292be51:${_ppa}
