# Template file for 'dgx-spark-config'
# Meta-package that pulls in all DGX Spark hardware support packages
pkgname=dgx-spark-config
version=1.0
revision=3
short_desc="NVIDIA DGX Spark system configuration (meta-package)"
maintainer="Void DGX Spark <void-dgx-spark@example.com>"
license="MIT"
homepage="https://github.com/<user>/void-dgx-spark"
create_wrksrc=yes

archs="aarch64"

depends="
 linux-dgx-spark
 nvidia-dgx-spark
 nvidia-dgx-spark-modules
 nvidia-dgx-spark-firmware
 dgx-dashboard
 nvidia-sbsa-gwdt-options
 nvidia-cppc-cpufreq-options
 nvidia-drm-options-modeset0
 nvidia-spark-realtek-mod-options
 nvidia-kernel-defaults
 nvidia-disable-aqc-nic
 nvidia-disable-init-on-alloc
 nvidia-disable-numa-balancing
 nvidia-nvme-options
 nvidia-earlycon
 nvidia-spark-initcall-bl
 nvidia-spark-grub-pci
 mstflint
 nvidia-mlnx-tools
 dgx-spark-mlnx-hotplug
 nvidia-spark-mlnx-firmware-manager
 nvidia-mstflint-loader
 nv-cpu-governor
 nv-common-apis
 nvidia-relaxed-ordering-nvme
 fwupd"

do_install() {
	# Dracut configuration for initramfs (not covered by any Ubuntu package)
	vinstall ${FILESDIR}/dgx-spark-dracut.conf 644 usr/lib/dracut/dracut.conf.d

	# Module blacklist for nouveau/r8169/coresight (combined from NixOS port)
	vinstall ${FILESDIR}/dgx-spark-blacklist.conf 644 usr/lib/modprobe.d

	# Resource limits for RDMA and NVIDIA (nofile + memlock)
	# From nv-limits 25.10-1 on DGX OS
	vinstall ${FILESDIR}/nv-limits.conf 644 etc/security/limits.d

	# Sysctl tuning
	vinstall ${FILESDIR}/dgx-spark-sysctl.conf 644 usr/lib/sysctl.d

	# RDMA module loading is handled by rdma-core's 09-rdma.sh core-service
}
